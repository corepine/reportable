{
    "name": "corepine/reportable",
    "description": "Reusable polymorphic reporting for Laravel models with a starter Blade UI.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "reportable",
        "reports",
        "moderation",
        "blade",
        "corepine"
    ],
    "authors": [
        {
            "name": "Namu Makwembo",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "livewire/livewire": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.34|^3.0",
        "pestphp/pest-plugin-laravel": "^2.4|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Corepine\\Reportable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Corepine\\Reportable\\Tests\\": "tests/",
            "Workbench\\": "workbench/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "test": [
            "@php vendor/bin/pest"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Corepine\\Reportable\\ReportableServiceProvider"
            ],
            "aliases": {
                "Reportable": "Corepine\\Reportable\\Facades\\Reportable"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
